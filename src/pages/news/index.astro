---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const newsEntries = await getCollection('news');
newsEntries.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const newsWithContent = await Promise.all(newsEntries.map(async (entry) => {
  const { Content } = await entry.render();
  return { ...entry, Content };
}));
---

<BaseLayout title="News">
  <div class="py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-20">
        <h1 class="text-5xl font-serif text-gold mb-6 tracking-[0.2em] uppercase">News</h1>
        <div class="w-24 h-px bg-gold/20 mx-auto"></div>
      </div>

      <div class="space-y-12">
        {newsWithContent.map(entry => (
          <button 
            data-news-id={entry.slug}
            class="news-trigger block w-full text-left group border-b border-gold/10 pb-12 hover:border-gold/30 transition-all cursor-pointer"
          >
            <article>
              <div class="flex items-center gap-4 mb-4">
                <span class="text-[9px] text-gold border border-gold/40 px-3 py-1 uppercase tracking-widest">{entry.data.category}</span>
                <span class="text-[10px] text-gold/40 font-serif">{entry.data.publishDate}</span>
              </div>
              <h2 class="text-2xl font-serif text-[#D1D1C7] group-hover:text-gold transition-colors mb-4 uppercase">
                {entry.data.title}
              </h2>
              <p class="text-sm text-[#D1D1C7]/60 italic leading-relaxed">
                "{entry.data.excerpt}"
              </p>
              <div class="mt-6 text-[10px] text-gold/20 group-hover:text-gold/60 transition-colors uppercase tracking-widest">
                Unlock Detailed Scroll ?
              </div>
            </article>

            <template id={`content-${entry.slug}`}>
                <div class="space-y-12 py-10">
                    <header class="text-center flex flex-col items-center">
                        <div class="mb-10 w-full flex justify-center">
                            <span class="text-[9px] text-gold border border-gold/40 px-4 py-1 uppercase tracking-[0.3em] bg-gold/5">{entry.data.category}</span>
                        </div>
                        <h1 class="text-3xl md:text-5xl font-serif text-gold mb-10 uppercase tracking-tighter leading-tight">
                            {entry.data.title}
                        </h1>
                        <div class="text-[9px] text-gold/40 uppercase tracking-[0.2em] font-serif italic mb-2">Penned by {entry.data.author}</div>
                        <div class="text-[8px] text-[#D1D1C7]/20 uppercase tracking-widest">Released on {entry.data.publishDate}</div>
                    </header>
                    <div class="prose prose-invert prose-gold max-w-none text-base leading-relaxed font-serif">
                        <entry.Content />
                    </div>

                    <div class="mt-16 pt-8 border-t border-gold/10 text-center">
                        <p class="text-[9px] text-gold/30 uppercase tracking-[0.3em] mb-6 italic">Your support helps us keep forging.</p>
                        <a href="/donations" class="inline-block border border-gold/40 text-gold px-10 py-3 text-[10px] font-serif font-bold tracking-[0.2em] hover:bg-gold hover:text-void transition-all uppercase">
                            Support the Sect
                        </a>
                    </div>
                </div>
            </template>
          </button>
        ))}
      </div>
    </div>
  </div>

  <div id="news-modal" class="fixed inset-0 z-[100] flex items-center justify-center opacity-0 pointer-events-none transition-all duration-500 backdrop-blur-xl bg-void/80 p-4">
    <div class="relative w-full max-w-3xl max-h-[85vh] bg-void-light border border-gold/20 overflow-y-auto custom-scrollbar shadow-[0_0_50px_rgba(0,0,0,0.8)]">
        <button id="close-modal" class="sticky top-4 right-4 ml-auto w-10 h-10 flex items-center justify-center text-gold/40 hover:text-gold transition-colors z-[110] bg-void/80 rounded-full border border-gold/10">×</button>
        <div id="modal-content-area" class="px-8 md:px-16 pb-20"></div>
    </div>
  </div>

  <script>
    const triggers = document.querySelectorAll('.news-trigger');
    const modal = document.getElementById('news-modal');
    const contentArea = document.getElementById('modal-content-area');
    const closeBtn = document.getElementById('close-modal');

    triggers.forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-news-id');
            const template = document.getElementById(`content-${id}`);
            if (template && modal && contentArea) {
                contentArea.innerHTML = template.innerHTML;
                modal.classList.remove('opacity-0', 'pointer-events-none');
                document.body.style.overflow = 'hidden';
            }
        });
    });

    const closeModal = () => {
        if (modal) {
            modal.classList.add('opacity-0', 'pointer-events-none');
            document.body.style.overflow = '';
        }
    };

    closeBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });
  </script>

  <style is:global>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #050505; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #C5A05933; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #C5A05966; }
  </style>
</BaseLayout>
