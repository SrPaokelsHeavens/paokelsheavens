---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { defaultLang, ui, languages } from '../../i18n/ui';

const url = Astro.url;
const pathSegments = url.pathname.split('/').filter(Boolean);
const lang = Object.keys(languages).includes(pathSegments[0]) ? pathSegments[0] : defaultLang;
const t = ui[lang as keyof typeof ui] || ui[defaultLang];
---

<BaseLayout title={t['donations.title']} description={t['donations.desc']}>
  <div class="py-20">
    <!-- PayPal SDK Loaded Here -->
    <script is:inline src="https://www.paypal.com/sdk/js?client-id=BAAGyb0oeyqeIqm1YKRBJnSeEjNEkmCS_FGyALdI7Tanh3oVHz1_dD82SuXk-B1hk30HyM9VrIvu2UQkJE&components=hosted-buttons&disable-funding=venmo&currency=USD"></script>

    <div class="container mx-auto px-4 max-w-4xl">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl font-serif text-gold mb-4 uppercase tracking-widest">{t['donations.title']}</h1>
        <div class="w-16 h-px bg-gold/30 mx-auto"></div>
      </div>

      <!-- Informational Content -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-20">
        <div class="space-y-6">
          <h2 class="text-2xl font-serif text-[#D1D1C7]">{t['donations.why_title']}</h2>
          <p class="text-sm text-[#D1D1C7]/70 leading-relaxed">
            {t['donations.why_desc']}
          </p>
          <ul class="text-[11px] space-y-3 text-gold/60 uppercase tracking-widest">
            <li class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 bg-gold rounded-full"></span>
              {t['donations.benefit_1']}
            </li>
            <li class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 bg-gold rounded-full"></span>
              {t['donations.benefit_2']}
            </li>
            <li class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 bg-gold rounded-full"></span>
              {t['donations.benefit_3']}
            </li>
          </ul>
        </div>
        <div class="bg-void-light border border-gold/10 p-8 text-center italic text-gold/40 text-sm">
          {t['donations.quote']}
        </div>
      </div>

      <!-- Personalized Message -->
      <div class="max-w-2xl mx-auto mb-16 text-center space-y-4">
        <p class="text-[11px] text-[#D1D1C7]/50 leading-relaxed uppercase tracking-widest">
          Dear Reader, By making a contribution, you are directly helping us bring you better content and daily updates for the novels you love. We truly appreciate your support!
        </p>
        <p class="text-[9px] text-gold/30 italic tracking-tighter">
          Feel free to tell us your opinions in the customer notes, or maybe your nickname for making you part of our Weekly Dao Table (optional)
        </p>
      </div>

      <!-- Payment Methods Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20 items-stretch">
        <!-- PayPal Block -->
        <div class="bg-void-light p-10 border border-gold/10 flex flex-col items-center justify-center min-h-[400px]">
          <div class="w-full max-w-[300px]">
            <div id="paypal-container-FA9AKAMVV7APS"></div>
            <script is:inline>
              paypal.HostedButtons({
                hostedButtonId: "FA9AKAMVV7APS",
              }).render("#paypal-container-FA9AKAMVV7APS")
            </script>
          </div>
          <p class="mt-8 text-[10px] text-gold/30 uppercase tracking-widest font-serif">Mortal Support • PayPal</p>
        </div>

        <!-- Ko-fi Block -->
        <div class="bg-void-light border border-gold/10 overflow-hidden">
          <iframe id='kofiframe' src='https://ko-fi.com/srpaokels/?hidefeed=true&widget=true&embed=true&preview=true' style='border:none;width:100%;padding:4px;background:#f9f9f9;' height='712' title='srpaokels'></iframe>
        </div>
      </div>

      <!-- Crypto -->
      <div class="grid grid-cols-1 gap-6 mb-20">
        <a href="#" class="group bg-void-light border border-gold/10 p-6 text-center hover:border-gold transition-all opacity-50">
          <div class="text-gold font-serif mb-2 group-hover:scale-110 transition-transform uppercase text-sm italic tracking-widest">Cryptocurrency Vault</div>
          <div class="text-[8px] text-gold/30 tracking-[0.2em] uppercase">BTC / ETH / SOL</div>
        </a>
      </div>

      <!-- Final Note -->
      <div class="text-center p-8 border border-dashed border-gold/10 text-[10px] text-[#D1D1C7]/40 uppercase tracking-[0.3em]">
        {t['donations.note']}
      </div>
    </div>
  </div>
</BaseLayout>