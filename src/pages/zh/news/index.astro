---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { ui } from '../../../i18n/ui';

const lang = 'zh';
const t = ui[lang];

const newsEntries = await getCollection('news');
newsEntries.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
---

<BaseLayout title={t['nav.news']}>
  <div class="py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-20">
        <h1 class="text-5xl font-serif text-gold mb-6 tracking-[0.2em] uppercase">{t['nav.news']}</h1>
        <div class="w-24 h-px bg-gold/20 mx-auto"></div>
      </div>

      <div class="space-y-12">
        {newsEntries.map(entry => (
          <a href={`/zh/news/${entry.slug}`} class="block group border-b border-gold/10 pb-12 hover:border-gold/30 transition-all">
            <article>
              <div class="flex items-center gap-4 mb-4">
                <span class="text-[9px] text-gold border border-gold/40 px-3 py-1 uppercase tracking-widest">{entry.data.category}</span>
                <span class="text-[10px] text-gold/40 font-serif">{entry.data.publishDate}</span>
              </div>
              <h2 class="text-2xl font-serif text-[#D1D1C7] group-hover:text-gold transition-colors mb-4 uppercase">
                {entry.data.title}
              </h2>
              <p class="text-sm text-[#D1D1C7]/60 italic leading-relaxed">
                "{entry.data.excerpt}"
              </p>
              <div class="mt-6 text-[10px] text-gold/20 group-hover:text-gold/60 transition-colors uppercase tracking-widest">
                阅读详细卷轴 →
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>