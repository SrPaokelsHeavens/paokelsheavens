---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const tierOrder = [
  'Celestial Body Refining Realm',
  'Celestial Foundation Realm',
  'Celestial Core Realm',
  'Celestial Soul Realm',
  'Celestial Transformation Realm',
  'Celestial Sovereign Realm',
];

const tierEntries = await getCollection('daoTiers');
const tierLookup = new Map(
  tierEntries.map((entry) => [entry.data.tier, { image: entry.data.image, summary: entry.data.summary }])
);

const daoTableEntries = (await getCollection('daoTableEntries')).filter((entry) => entry.data.status === 'active');
const orderedRows = daoTableEntries
  .sort((a, b) => {
    const tierDiff = tierOrder.indexOf(a.data.tier) - tierOrder.indexOf(b.data.tier);
    if (tierDiff !== 0) return tierDiff;
    return a.data.alias.localeCompare(b.data.alias);
  })
  .map((entry) => ({
    alias: entry.data.alias,
    cultivationLevel: entry.data.cultivationLevel,
    tier: entry.data.tier,
    joined: entry.data.joined,
    note: entry.data.note,
    status: entry.data.status,
    image: tierLookup.get(entry.data.tier)?.image,
  }));

const archiveCards = [
  {
    title: 'Celestial Tiers',
    description: 'Browse every tier blueprint and reserve upcoming slots.',
    href: '/dao-table/celestial-tiers',
  },
  {
    title: 'Sect Immortal Members',
    description: 'Meet the monthly patrons keeping the sect breathing.',
    href: '/dao-table/sect-immortal-members',
  },
  {
    title: 'Immortal Spirits',
    description: 'Hall for legendary benefactors – opening soon.',
    href: '/dao-table/immortal-spirits',
  },
];
---

<BaseLayout title="Dao Table" description="Ledger of every cultivator sustaining Sr. Paokel's Heavens.">
  <section class="pt-20 pb-12 bg-void">
    <div class="container mx-auto px-4 text-center max-w-3xl">
      <p class="text-[10px] tracking-[0.35em] uppercase text-gold/70 mb-4">Ledger of Tributes</p>
      <h1 class="text-5xl font-serif text-gold tracking-[0.15em] uppercase mb-4">Dao Table</h1>
      <p class="text-sm text-[#d1d1c7]/70">Every ledger slot below represents a cultivator who tithed to keep the heavens lit. The table updates itself as new Markdown records are committed.</p>
    </div>
  </section>

  <section class="container mx-auto px-4 py-16">
    <div class="flex flex-col gap-6 mb-12 text-center">
      <h2 class="text-2xl font-serif text-gold tracking-[0.3em] uppercase">Recognized Contributors</h2>
      <p class="text-sm text-[#d1d1c7]/60">Grid auto-expands as you add or remove Markdown entries inside <code>src/content/dao-table/table</code>.</p>
    </div>

    {orderedRows.length === 0 ? (
      <div class="border border-dashed border-gold/20 text-center py-16 text-sm text-gold/50 uppercase tracking-[0.3em]">Awaiting first ledger entry</div>
    ) : (
      <div class="dao-table-grid">
        {orderedRows.map((row) => (
          <article class="dao-table-card">
            {row.image && <div class="dao-table-card__image" style={`background-image: url(${row.image});`}></div>}
            <div class="dao-table-card__body">
              <p class="text-[10px] text-gold/60 uppercase tracking-[0.4em] mb-3">{row.tier}</p>
              <h3 class="text-2xl font-serif text-gold tracking-[0.05em]">{row.alias}</h3>
              <p class="text-xs text-[#d1d1c7]/60 italic mb-4">{row.cultivationLevel}</p>
              {row.note && <p class="text-sm text-[#d1d1c7]/70">{row.note}</p>}
              <div class="text-[10px] text-gold/40 uppercase tracking-[0.3em] mt-6 flex justify-between">
                <span>{row.status}</span>
                <span>{row.joined ? `Since ${row.joined}` : 'Active'}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>

  <section class="bg-void-light/30 py-16">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-[10px] tracking-[0.35em] uppercase text-gold/70 mb-4">Sub-ledgers</p>
        <h2 class="text-3xl font-serif text-gold tracking-[0.2em] uppercase">Celestial Archives</h2>
        <p class="text-sm text-[#d1d1c7]/70">Each archive below is powered entirely by Markdown – click anywhere on the card to drill into its page.</p>
      </div>
      <div class="archive-grid">
        {archiveCards.map((card) => (
          <a href={card.href} class="archive-card">
            <div>
              <p class="text-[10px] text-gold/50 uppercase tracking-[0.4em] mb-3">Open Ledger</p>
              <h3 class="text-2xl font-serif text-gold mb-3">{card.title}</h3>
              <p class="text-sm text-[#d1d1c7]/70">{card.description}</p>
            </div>
            <span class="text-gold text-sm tracking-[0.3em] uppercase">Enter ?</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .dao-table-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .dao-table-card {
    position: relative;
    border: 1px solid rgba(197, 160, 89, 0.2);
    background: rgba(5, 5, 5, 0.85);
    min-height: 280px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .dao-table-card__image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.12;
  }

  .dao-table-card__body {
    position: relative;
    padding: 1.75rem;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .archive-card {
    border: 1px solid rgba(197, 160, 89, 0.2);
    padding: 2rem;
    background: rgba(5, 5, 5, 0.85);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 220px;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .archive-card:hover {
    border-color: rgba(197, 160, 89, 0.6);
    transform: translateY(-6px);
  }
</style>

