---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Immortal Spirits" description="Hall reserved for legendary benefactors.">
  <section class="min-h-[60vh] flex items-center justify-center text-center px-4">
    <div class="max-w-2xl">
      <p class="text-[10px] tracking-[0.35em] uppercase text-gold/60 mb-4">Dao Table Subpage</p>
      <h1 class="text-4xl font-serif text-gold tracking-[0.15em] uppercase mb-6">Immortal Spirits</h1>
      <p class="text-sm text-[#d1d1c7]/70 mb-8">This vault will archive the greatest benefactors in sect history. Content is authored via Markdown and will unlock after the next release.</p>
      <div class="inline-flex items-center gap-3 border border-gold/30 px-6 py-3 text-[11px] uppercase tracking-[0.3em] text-gold/70">Coming Soon</div>
    </div>
  </section>
</BaseLayout>
