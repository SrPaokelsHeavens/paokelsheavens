---
import BaseLayout from '../layouts/BaseLayout.astro';
import CelestialCarousel from '../components/Chronicles/CelestialCarousel.astro';
import ReadingProgress from '../components/ui/ReadingProgress.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, useLocalizedPath } from '../i18n/utils';

// Language detection
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = useLocalizedPath(lang);

// --- CELESTIAL ORCHESTRATOR (The Mirror) ---
const controlEntries = await getCollection('settings');
const control = controlEntries.length > 0 ? controlEntries[0].data : {
    chapterDaysOnDisplay: 0,
    newsDaysOnDisplay: 15,
    maxTotalCards: 15,
    featuredFirst: true,
    displayType: 'all'
};

const rawCarousel = await getCollection('carousel');

// Debug: Check if we have cards
// console.log('Raw Cards:', rawCarousel.length);

// 1. Filtering by Type and Blacklist
let filtered = rawCarousel.filter(card => {
    if (control.displayType && control.displayType !== 'all' && card.data.type !== control.displayType) return false;
    
    // Date Filtering (Days on Display)
    const now = new Date();
    const pubDate = new Date(card.data.publishDate);
    const diffTime = Math.abs(now.getTime() - pubDate.getTime());
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    
    if (card.data.type === 'chapter' && control.chapterDaysOnDisplay > 0 && diffDays > control.chapterDaysOnDisplay) return false;
    if (card.data.type === 'news' && control.newsDaysOnDisplay > 0 && diffDays > control.newsDaysOnDisplay) return false;

    return true;
});

// 2. Sorting Logic (Sovereign Order)
const allEvents = filtered.sort((a, b) => {
    // A. Priority List (Pinning)
    const pA = control.priorityList?.indexOf(a.data.sourceId);
    const pB = control.priorityList?.indexOf(b.data.sourceId);
    if (pA !== -1 && pB !== -1) return pA - pB;
    if (pA !== -1) return -1;
    if (pB !== -1) return 1;

    // B. Featured First
    if (control.featuredFirst) {
        if (a.data.featured && !b.data.featured) return -1;
        if (!a.data.featured && b.data.featured) return 1;
    }

    // C. Type Priority
    if (control.typePriority) {
        const tA = control.typePriority.indexOf(a.data.type);
        const tB = control.typePriority.indexOf(b.data.type);
        if (tA !== tB) return tA - tB;
    }

    // D. Date (Newest first)
    return new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime();
}).slice(0, control.maxTotalCards || 15).map(card => ({
    id: card.id,
    type: card.data.type,
    title: card.data.title,
    excerpt: card.data.excerpt,
    url: card.data.url,
    image: card.data.image,
    metadata: { 
      date: card.data.publishDate,
      author: 'Sect Record' 
    }
}));
---

<BaseLayout title="Home">
	<!-- Hero Section -->
	<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden py-20">
		<div class="absolute inset-0 z-0">
			<div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-gold/5 blur-[120px] rounded-full animate-pulse"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-blood/5 blur-[150px] rounded-full animate-pulse" style="animation-delay: 2s;"></div>
		</div>
		
		<div class="container mx-auto px-4 relative z-10 text-center">
			<div class="inline-block mb-8 px-4 py-1.5 border border-gold/20 rounded-full bg-gold/5 text-[9px] tracking-[0.4em] text-gold uppercase animate-pulse">
				Immortal Path • {lang.toUpperCase()}
			</div>
			
			<h1 class="hero-title font-serif font-bold mb-10 tracking-tighter leading-[0.8] transition-all">
				<span class="text-gold block">PAOKELS</span>
				<span class="hero-subtitle text-[#D1D1C7] opacity-80 italic">HEAVENS</span>
			</h1>

<style>
	.hero-title {
		font-size: clamp(2.8rem, 18vw, 3.75rem);
	}
	.hero-subtitle {
		font-size: clamp(1.8rem, 12vw, 2.25rem);
	}

	@media (min-width: 768px) {
		.hero-title { font-size: 6rem; }
		.hero-subtitle { font-size: 3.75rem; }
	}

	@media (min-width: 1024px) {
		.hero-title { font-size: 8rem; }
		.hero-subtitle { font-size: 4.5rem; }
	}
</style>
			
			<div class="w-full mb-4 text-center">
				<h2 class="chronicles-title font-serif tracking-[0.4em] mr-[-0.4em] uppercase text-gold leading-none block mx-auto">
					{t('chronicles.title')}
				</h2>
				<div class="w-20 h-px bg-gold/20 mx-auto mt-3"></div>
			</div>
			
			<CelestialCarousel events={allEvents} />
			
			<div class="flex flex-col md:flex-row gap-6 justify-center items-center">
				<a href={l('library')} class="w-full md:w-auto bg-gold text-void px-12 py-5 font-serif font-bold tracking-[0.2em] text-[11px] hover:bg-[#D4AF37] hover:shadow-[0_0_30px_rgba(197,160,89,0.3)] transition-all transform hover:-translate-y-1">
					{t('hero.cta.read')}
				</a>
				<a href={l('community')} class="w-full md:w-auto border border-gold/40 text-gold px-12 py-5 font-serif font-bold tracking-[0.2em] text-[11px] hover:bg-gold/10 transition-all">
					{t('hero.cta.join')}
				</a>
			</div>

			<ReadingProgress />
		</div>

		<div class="absolute left-8 top-1/2 -translate-y-1/2 hidden lg:block opacity-10 [writing-mode:vertical-rl] text-gold text-[10px] tracking-[1.5em] uppercase">
			Resilience • Power • Ascension
		</div>
		<div class="absolute right-8 top-1/2 -translate-y-1/2 hidden lg:block opacity-10 [writing-mode:vertical-rl] text-gold text-[10px] tracking-[1.5em] uppercase">
			Wisdom • Fate • Honor
		</div>
	</section>
</BaseLayout>

<style>
	.hero-title {
		font-size: clamp(2.8rem, 18vw, 3.75rem);
	}
	.hero-subtitle {
		font-size: clamp(1.8rem, 12vw, 2.25rem);
	}

	.chronicles-title {
		font-size: 1.1rem;
	}

	@media (max-width: 516px) {
		.chronicles-title {
			font-size: 3.5vw;
		}
	}

	@media (min-width: 768px) {
		.hero-title { font-size: 6rem; }
		.hero-subtitle { font-size: 3.75rem; }
	}

	@media (min-width: 1024px) {
		.hero-title { font-size: 8rem; }
		.hero-subtitle { font-size: 4.5rem; }
	}
</style>
