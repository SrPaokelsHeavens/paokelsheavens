---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import donors from '../../../data/donors.json';
import { defaultLang } from '../../../i18n/ui';

const url = Astro.url;
const [, lang = defaultLang] = url.pathname.split('/');

const localT = {
    es: { title: 'Mesa del Dao', subtitle: 'Honor a los Contribuidores del Camino', desc: '"La ascensión no es solo un acto de fuerza, sino de voluntad compartida."', cta: 'Ascender ahora' },
    en: { title: 'Dao Table', subtitle: 'Honor to the Path Contributors', desc: '"Ascension is not just an act of strength, but of shared will."', cta: 'Ascend now' },
    zh: { title: '道榜', subtitle: '致敬道路贡献者', desc: '“升天不只是力量的行为，更是共同意志的体现。”', cta: '现在升天' }
};
const pageT = localT[lang as keyof typeof localT] || localT[defaultLang];

const immortals = donors.filter(d => d.rank === 'Immortal');
const elders = donors.filter(d => d.rank === 'Sect Elder');
const disciples = donors.filter(d => d.rank === 'Core Disciple');
---

<BaseLayout title={pageT.title}>
  <div class="py-20">
    <div class="container mx-auto px-4">
      <div class="text-center mb-20">
        <h1 class="text-5xl font-serif text-gold mb-6 tracking-[0.2em] uppercase">{pageT.title}</h1>
        <p class="text-sm text-gold/40 tracking-widest uppercase mb-8">{pageT.subtitle}</p>
        <div class="max-w-2xl mx-auto italic text-[#D1D1C7]/60 font-serif">
          {pageT.desc}
        </div>
      </div>

      <div class="mb-20">
        <h2 class="text-center font-serif text-gold/80 text-xs tracking-[0.5em] uppercase mb-12 flex items-center justify-center gap-4">
          <span class="w-12 h-px bg-gold/20"></span>
          Immortal Patrons
          <span class="w-12 h-px bg-gold/20"></span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
          {immortals.map(d => (
            <div class="relative group">
              <div class="absolute -inset-0.5 bg-gold/20 rounded-lg blur opacity-30 group-hover:opacity-100 transition duration-1000 animate-pulse"></div>
              <div class="relative bg-void border border-gold/40 p-6 text-center">
                <div class="text-gold font-serif text-xl mb-2 tracking-widest">{d.name}</div>
                <div class="text-[9px] text-gold/40 uppercase tracking-widest">Rank: Immortal</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-32 text-center">
        <a href={`/${lang}/donations`} class="inline-block border border-gold text-gold px-12 py-4 font-serif text-xs tracking-[0.3em] hover:bg-gold hover:text-void transition-all uppercase">
          {pageT.cta}
        </a>
      </div>
    </div>
  </div>
</BaseLayout>