---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title={t['donations.title']} description={t['donations.desc']}>
  <div class="py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl font-serif text-gold mb-4 uppercase tracking-widest">Apoyar a la Secta</h1>
        <div class="w-16 h-px bg-gold/30 mx-auto"></div>
      </div>

      <!-- Contenido Informativo -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-20">
        <div class="space-y-6">
          <h2 class="text-2xl font-serif text-[#D1D1C7]">¿Por qué contribuir?</h2>
          <p class="text-sm text-[#D1D1C7]/70 leading-relaxed">
            Cada capítulo traducido, cada actualización del sistema y el mantenimiento del Espíritu Guardián (Bot) requiere energía espiritual y recursos del mundo mortal.
          </p>
          <ul class="text-[11px] space-y-3 text-gold/60 uppercase tracking-widest">
            <li class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 bg-gold rounded-full"></span>
              Traducciones más rápidas
            </li>
            <li class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 bg-gold rounded-full"></span>
              Servidores sin lag
            </li>
            <li class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 bg-gold rounded-full"></span>
              Nuevas funcionalidades de IA
            </li>
          </ul>
        </div>
        <div class="bg-void-light border border-gold/10 p-8 text-center italic text-gold/40 text-sm">
          "Aquel que planta un árbol para que otros disfruten de su sombra, ha entendido el verdadero camino del Dao."
        </div>
      </div>

      <!-- Métodos de Pago -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-20">
        <!-- PayPal -->
        <a href="#" class="group bg-void-light border border-gold/10 p-10 text-center hover:border-gold transition-all">
          <div class="text-gold font-serif mb-4 group-hover:scale-110 transition-transform">PAYPAL</div>
          <div class="text-[8px] text-gold/30 tracking-[0.2em] uppercase">Donación Directa</div>
        </a>
        <!-- Patreon -->
        <a href="#" class="group bg-void-light border border-gold/10 p-10 text-center hover:border-gold transition-all">
          <div class="text-gold font-serif mb-4 group-hover:scale-110 transition-transform">PATREON</div>
          <div class="text-[8px] text-gold/30 tracking-[0.2em] uppercase">Suscripción Mensual</div>
        </a>
        <!-- Crypto -->
        <a href="#" class="group bg-void-light border border-gold/10 p-10 text-center hover:border-gold transition-all">
          <div class="text-gold font-serif mb-4 group-hover:scale-110 transition-transform">CRYPTO</div>
          <div class="text-[8px] text-gold/30 tracking-[0.2em] uppercase">BTC / ETH / SOL</div>
        </a>
      </div>

      <!-- Nota Final -->
      <div class="text-center p-8 border border-dashed border-gold/10 text-[10px] text-[#D1D1C7]/40 uppercase tracking-[0.3em]">
        {t['donations.note']}
      </div>
    </div>
  </div>
</BaseLayout>
