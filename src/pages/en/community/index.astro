---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SocialCard from '../../../components/Social/SocialCard.astro';
import { defaultLang, ui, languages } from '../../../i18n/ui';

const url = Astro.url;
const pathSegments = url.pathname.split('/').filter(Boolean);
const lang = Object.keys(languages).includes(pathSegments[0]) ? pathSegments[0] : defaultLang;
const t = ui[lang as keyof typeof ui] || ui[defaultLang];

const socialPlatforms = [
  {
    platform: 'TikTok',
    url: '#',
    description: 'Snippets of legends and epic moments.',
    color: '#ff0050',
    iconName: 'tiktok'
  },
  {
    platform: 'YouTube',
    url: '#',
    description: 'Deep analysis and cultivation streams.',
    color: '#ff0000',
    iconName: 'youtube'
  },
  {
    platform: 'Facebook',
    url: '#',
    description: 'Daily news and sect art.',
    color: '#1877f2',
    iconName: 'facebook'
  }
];
---

<BaseLayout title={t['community.title']} description={t['community.desc']}>
  <div class="py-20">
    <div class="container mx-auto px-4 max-w-6xl">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-5xl font-serif text-gold mb-6 tracking-widest uppercase">{t['community.title']}</h1>
        <div class="w-24 h-px bg-gold/30 mx-auto mb-8"></div>
        <p class="text-[#D1D1C7]/60 italic max-w-2xl mx-auto">
          {t['community.quote']}
        </p>
      </div>

      <!-- Discord Featured Section -->
      <div class="mb-20">
        <div class="relative bg-void-light border border-gold/30 p-1 md:p-12 overflow-hidden group">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(88,101,242,0.1),transparent_70%)]"></div>
          
          <div class="relative z-10 flex flex-col md:flex-row items-center gap-12">
            <div class="flex-1 text-center md:text-left space-y-6">
              <div class="inline-block px-3 py-1 border border-gold/20 text-[10px] text-gold tracking-widest uppercase">{t['community.discord_tag']}</div>
              <h2 class="text-4xl font-serif text-[#D1D1C7]">{t['community.discord_title']}</h2>
              <p class="text-sm text-[#D1D1C7]/60 leading-relaxed">
                {t['community.discord_desc']}
              </p>
              <div class="flex flex-wrap gap-6 justify-center md:justify-start text-[10px] text-gold/40 uppercase tracking-widest">
                <span>• {t['community.discord_feature_1']}</span>
                <span>• {t['community.discord_feature_2']}</span>
                <span>• {t['community.discord_feature_3']}</span>
              </div>
              <a href="#" class="inline-block bg-[#5865F2] text-white px-10 py-4 font-bold tracking-widest hover:bg-[#4752C4] transition-all uppercase text-xs">
                {t['community.discord_cta']}
              </a>
            </div>
            
            <div class="flex-1 w-full max-w-sm">
                <!-- Discord Widget Mockup -->
                <div class="bg-void border border-gold/10 p-6 rounded-lg shadow-2xl">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-12 h-12 bg-[#5865F2] rounded-full flex items-center justify-center font-bold">SP</div>
                        <div>
                            <div class="text-sm font-bold text-white uppercase tracking-wider">Sr. Paokel's Heavens</div>
                            <div class="text-[10px] text-green-500 uppercase tracking-tighter flex items-center gap-1">
                                <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
                                452 {t['community.discord_stats']}
                            </div>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <div class="h-2 w-full bg-gold/5 rounded"></div>
                        <div class="h-2 w-3/4 bg-gold/5 rounded"></div>
                        <div class="h-2 w-1/2 bg-gold/5 rounded"></div>
                    </div>
                </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Social Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {socialPlatforms.map(social => (
          <SocialCard {...social} />
        ))}
      </div>

      <!-- Contact Mini Section -->
      <div class="mt-32 border-t border-gold/5 pt-20 text-center">
        <h3 class="text-xl font-serif text-gold mb-6 uppercase tracking-widest">{t['community.contact_title']}</h3>
        <p class="text-xs text-[#D1D1C7]/40 mb-10 max-w-lg mx-auto uppercase tracking-tighter">
            {t['community.contact_desc']}
        </p>
        <a href="mailto:admin@srpaokelsheavens.eu.org" class="text-gold border-b border-gold/20 hover:border-gold transition-all pb-1 font-serif tracking-[0.2em] text-sm">
            {t['community.contact_cta']}
        </a>
      </div>
    </div>
  </div>
</BaseLayout>