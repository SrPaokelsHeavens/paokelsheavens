---
import BaseLayout from '../../layouts/BaseLayout.astro';

const contactChannels = [
  {
    title: 'Imperial Dispatch',
    badge: 'Release Feed',
    description: 'Official release notes, chapter recaps, and build decisions posted after every deployment.',
    action: 'Read Newsroom',
    url: '/news',
  },
  {
    title: 'Dao Table Ledger',
    badge: 'Transparency',
    description: 'Contribution tiers and financial acknowledgements are tracked openly on the Dao Table.',
    action: 'Visit Dao Table',
    url: '/dao-table',
  },
  {
    title: 'Direct Contact',
    badge: 'Support',
    description: 'Need coordination, have a request, or spotted an issue? Email the archivist for a same-day response.',
    action: 'Email the Archivist',
    url: 'mailto:admin@paokelsheavens.asia',
  }
];

const operationalNotes = [
  {
    label: 'Library Updates',
    detail: 'New chapters enter review via the Imperial Dispatch before they appear inside the reader.',
    url: '/library',
  },
  {
    label: 'Donations & Support',
    detail: 'PayPal / Ko-fi remain the only funding portals; every contribution surfaces on the Dao Table.',
    url: '/donations',
  },
  {
    label: 'Carousel Broadcasts',
    detail: 'The hero carousel mirrors news, chapters, and soon Dao tiers. No external bots or live feeds are required.',
    url: '/',
  }
];
---

<BaseLayout title="The Community" description="Official signal routes, release notes, and contact information for Sr. Paokel's Heavens.">
  <div class="py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      <section class="text-center mb-16">
        <div class="inline-block mb-6 px-4 py-1 border border-gold/20 text-[10px] tracking-[0.35em] uppercase text-gold">Signal Beacon</div>
        <h1 class="text-5xl font-serif text-gold mb-6 tracking-tight uppercase">Community & Dispatch</h1>
        <p class="text-sm text-[#D1D1C7]/70 max-w-3xl mx-auto leading-relaxed">
          Every channel listed here is asynchronous and archived. There are no invite-only chats or disappearing announcements—
          just written dispatches, open ledgers, and one direct line to the archivist. If it is not documented here, it is not an official pathway.
        </p>
      </section>

      <section class="mb-24">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {contactChannels.map((channel) => (
            <article class="bg-void-light border border-gold/10 p-6 flex flex-col gap-4 text-left hover:border-gold/40 transition-all">
              <div class="text-[10px] tracking-[0.3em] text-gold uppercase">{channel.badge}</div>
              <h2 class="text-2xl font-serif text-gold leading-tight">{channel.title}</h2>
              <p class="text-sm text-[#D1D1C7]/60 flex-1">{channel.description}</p>
              <a href={channel.url} class="inline-flex items-center gap-2 text-[10px] tracking-[0.3em] uppercase text-gold border border-gold/30 px-5 py-2 hover:bg-gold hover:text-void transition-all">
                {channel.action}
                <span aria-hidden="true">?</span>
              </a>
            </article>
          ))}
        </div>
      </section>

      <section class="mb-24">
        <div class="border border-gold/10 p-8 bg-void-light/30">
          <h3 class="text-2xl font-serif text-gold uppercase tracking-[0.3em] mb-6">Operational Notes</h3>
          <div class="space-y-6">
            {operationalNotes.map((note) => (
              <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-gold/5 pb-4 last:border-none last:pb-0">
                <div>
                  <p class="text-sm font-serif text-gold uppercase tracking-[0.2em]">{note.label}</p>
                  <p class="text-xs text-[#D1D1C7]/60 mt-1 max-w-2xl">{note.detail}</p>
                </div>
                <a href={note.url} class="text-[10px] text-gold/70 uppercase tracking-[0.3em] hover:text-gold transition-colors">View</a>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="text-center border-t border-gold/10 pt-16">
        <h3 class="text-xl font-serif text-gold uppercase tracking-[0.4em] mb-4">Need to talk?</h3>
        <p class="text-sm text-[#D1D1C7]/60 mb-6 max-w-2xl mx-auto">
          All collaboration requests, support tickets, and governance questions go straight to the archivist mailbox. Attach as many details as possible; responses go out within 24 hours.
        </p>
        <a href="mailto:admin@paokelsheavens.asia" class="inline-flex items-center gap-2 text-sm font-serif text-void bg-gold px-8 py-3 tracking-[0.3em] uppercase hover:bg-[#D4AF37] transition-all">
          Email admin@paokelsheavens.asia
        </a>
      </section>
    </div>
  </div>
</BaseLayout>
