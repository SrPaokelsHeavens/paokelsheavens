---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, useLocalizedPath } from '../../../i18n/utils';

export async function getStaticPaths() {
  const novels = await getCollection('library', ({ data }) => data.type === 'novel');
  
  return novels.map(novel => {
    const cleanSlug = novel.slug.replace(/\/index$/, '').split('/')[0];
    return {
      params: { slug: cleanSlug },
      props: { novel },
    };
  });
}

const { novel } = Astro.props;
const { title, description, author, status, genres, cover, id } = novel.data as any;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = useLocalizedPath(lang);

// 1. Fetch all volumes for this novel
const volumes = await getCollection('library', (entry) => {
  return entry.data.type === 'volume' && (entry.data as any).novel_id === id;
});
volumes.sort((a, b) => (a.data as any).vol_number - (b.data as any).vol_number);

// 2. Fetch all chapters for this novel
const allChapters = await getCollection('library', (entry) => {
  return entry.data.type === 'chapter' && (entry.data as any).novel_id === id;
});

// Helper to get chapters for a specific volume
const getChaptersForVolume = (volId: string) => {
  return allChapters
    .filter(ch => (ch.data as any).vol_id === volId)
    .sort((a, b) => (a.data as any).chapter_number - (b.data as any).chapter_number);
};

// Find the very first chapter for the "Read First" button
const firstChapter = allChapters.sort((a, b) => {
    const aData = a.data as any;
    const bData = b.data as any;
    if (aData.vol_number !== bData.vol_number) return aData.vol_number - bData.vol_number;
    return aData.chapter_number - bData.chapter_number;
})[0];
---

<BaseLayout title={title}>
  <div class="relative py-20 overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-[400px] opacity-20 z-0">
        <img src={cover} alt="" class="w-full h-full object-cover blur-xl" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-void"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="mb-12">
        <div class="flex flex-wrap gap-3 mb-6">
          {genres?.map((genre: string) => (
            <span class="text-[9px] uppercase tracking-widest text-gold border border-gold/30 px-3 py-1 bg-gold/5">
              {genre}
            </span>
          ))}
          <span class="text-[9px] uppercase tracking-widest px-3 py-1 border border-gold/20 text-gold">
            {status}
          </span>
        </div>
        <h1 class="text-4xl md:text-7xl font-serif text-gold mb-4 uppercase tracking-tighter leading-none">{title}</h1>
        <div class="flex gap-6 text-xs text-[#D1D1C7]/40 uppercase tracking-widest font-serif">
           <span>{lang === 'es' ? 'Escrito por' : 'Penned by'} {author}</span>
        </div>
      </div>

      <div class="flex flex-col md:flex-row gap-12 items-start">
        <div class="w-full md:w-1/3 max-w-[350px] mx-auto md:mx-0 shadow-2xl border border-gold/20">
          <img src={cover} alt={title} class="w-full h-auto" />
        </div>

        <div class="flex-1 space-y-8">
          <div class="p-6 bg-void-light border-l-4 border-gold/20 italic text-[#D1D1C7]/80 text-sm leading-relaxed whitespace-pre-line">"{description}"</div>

          <div class="flex gap-4 pt-4">
            {firstChapter ? (
                <a href={l(`library/${firstChapter.slug}`)} class="bg-gold text-void px-10 py-4 font-serif font-bold text-xs tracking-[0.2em] hover:bg-[#D4AF37] transition-all uppercase shadow-lg">
                  {lang === 'es' ? 'Leer Primer Capítulo' : 'Read First Chapter'}
                </a>
            ) : (
                <button disabled class="bg-gray-800 text-gray-500 px-10 py-4 font-serif font-bold text-xs tracking-widest cursor-not-allowed uppercase">
                  {lang === 'es' ? 'No disponible' : 'Not available yet'}
                </button>
            )}
          </div>
        </div>
      </div>

      <!-- Hierarchical Chapter List (Volumes -> Chapters) -->
      <div class="mt-24 space-y-16">
        <h2 class="text-2xl font-serif text-gold mb-8 uppercase tracking-widest border-b border-gold/10 pb-4">{t('reader.index')}</h2>
        
        {volumes.length > 0 ? (
          volumes.map(volume => {
            const volChapters = getChaptersForVolume(volume.data.id as string);
            return (
              <div class="space-y-6">
                <div class="flex items-center gap-4">
                   <span class="text-gold/20 font-serif italic text-4xl">0{(volume.data as any).vol_number}</span>
                   <div>
                     <h3 class="text-lg font-serif text-gold uppercase tracking-widest">{(volume.data as any).title}</h3>
                     <p class="text-[10px] text-gold/40 uppercase tracking-[0.2em]">{lang === 'es' ? 'Archivos del Volumen' : 'Volume Archives'}</p>
                   </div>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 pl-4 border-l border-gold/5">
                  {volChapters.map(chapter => (
                    <a href={l(`library/${chapter.slug}`)} class="group p-4 border border-gold/5 hover:border-gold/30 hover:bg-gold/5 transition-all flex items-center justify-between">
                        <div>
                            <span class="text-[9px] text-gold/50 uppercase tracking-wider block mb-1">{lang === 'es' ? 'Entrada' : 'Entry'}: {(chapter.data as any).chapter_number}</span>
                            <h3 class="text-sm text-[#D1D1C7] font-serif group-hover:text-gold transition-colors">{chapter.data.title}</h3>
                        </div>
                        <span class="text-gold/20 group-hover:text-gold transition-colors">→</span>
                    </a>
                  ))}
                </div>
              </div>
            );
          })
        ) : (
          <div class="p-12 border border-dashed border-gold/10 text-center">
            <p class="text-gold/30 font-serif italic">{lang === 'es' ? 'Los archivos de esta crónica están siendo restaurados...' : 'The archives for this chronicle are being restored...'}</p>
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>