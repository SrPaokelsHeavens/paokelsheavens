---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventStream from '../../components/Chronicles/EventStream.astro';
import { ui } from '../../i18n/ui';

const lang = 'es';
const t = ui[lang];

const l = (path: string) => `/${lang}/${path.startsWith('/') ? path.slice(1) : path}`;

const mockEventsRow1 = [
  { type: 'capítulo', platform: 'web', title: 'Nueva técnica revelada: El Camino del Vacío Cap. 45', url: '#', metadata: { date: '05 Feb 2026', author: 'Sr. Paokel' } },
  { type: 'video', platform: 'youtube', title: 'Stream: Teorías sobre la ascensión de Xiao Lin', url: '#', metadata: { date: '04 Feb 2026', author: 'Admin' } },
  { type: 'actualización', platform: 'web', title: 'La Mesa del Dao ha sido actualizada. 3 nuevos Inmortales.', url: '#', metadata: { date: '03 Feb 2026', author: 'Sect' } },
];

const mockEventsRow2 = [
  { type: 'capítulo', platform: 'web', title: 'Tragedia en la Secta: El Despertar del Demonio Cap. 12', url: '#', metadata: { date: '01 Feb 2026', author: 'Sr. Paokel' } },
  { type: 'noticias', platform: 'web', title: 'Anuncio: Próximo sorteo de roles en Discord', url: '#', metadata: { date: '31 Ene 2026', author: 'Admin' } },
  { type: 'social', platform: 'facebook', title: 'Post: Arte conceptual de la Ciudad Prohibida', url: '#', metadata: { date: '30 Ene 2026', author: 'Sect' } },
];
---

<BaseLayout title="Inicio">
	<!-- Hero Section -->
	<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden py-20">
		<div class="absolute inset-0 z-0">
			<div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-gold/5 blur-[120px] rounded-full animate-pulse"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-blood/5 blur-[150px] rounded-full animate-pulse" style="animation-delay: 2s;"></div>
		</div>
		
		<div class="container mx-auto px-4 relative z-10 text-center">
			<div class="inline-block mb-8 px-4 py-1.5 border border-gold/20 rounded-full bg-gold/5 text-[9px] tracking-[0.4em] text-gold uppercase animate-pulse">
				Senda Inmortal • {lang.toUpperCase()}
			</div>
			
			<h1 class="text-6xl md:text-8xl lg:text-9xl font-serif font-bold mb-10 tracking-tighter leading-[0.8] transition-all">
				<span class="text-gold block">PAOKELS</span>
				<span class="text-[#D1D1C7] opacity-80 italic text-4xl md:text-6xl lg:text-7xl">HEAVENS</span>
			</h1>
			
			<div class="max-w-3xl mx-auto mb-16">
				<p class="text-base md:text-lg text-[#D1D1C7]/70 font-light leading-relaxed italic font-serif">
					"{t['hero.speech']}"
				</p>
			</div>
			
			<div class="flex flex-col md:flex-row gap-6 justify-center items-center">
				<a href={l('library')} class="w-full md:w-auto bg-gold text-void px-12 py-5 font-serif font-bold tracking-[0.2em] text-[11px] hover:bg-[#D4AF37] hover:shadow-[0_0_30px_rgba(197,160,89,0.3)] transition-all transform hover:-translate-y-1">
					{t['hero.cta.read']}
				</a>
				<a href={l('community')} class="w-full md:w-auto border border-gold/40 text-gold px-12 py-5 font-serif font-bold tracking-[0.2em] text-[11px] hover:bg-gold/10 transition-all">
					{t['hero.cta.join']}
				</a>
			</div>
		</div>

		<div class="absolute left-8 top-1/2 -translate-y-1/2 hidden lg:block opacity-10 [writing-mode:vertical-rl] text-gold text-[10px] tracking-[1.5em] uppercase">
			Resiliencia • Poder • Ascensión
		</div>
		<div class="absolute right-8 top-1/2 -translate-y-1/2 hidden lg:block opacity-10 [writing-mode:vertical-rl] text-gold text-[10px] tracking-[1.5em] uppercase">
			Sabiduría • Destino • Honor
		</div>
	</section>

	<!-- Sección Chronicles -->
	<section class="py-24 bg-void-light/40 border-y border-gold/5 overflow-hidden">
		<div class="container mx-auto px-4 mb-12">
			<h2 class="text-3xl font-serif text-center tracking-[0.3em] uppercase text-gold">{t['chronicles.title']}</h2>
			<div class="w-32 h-px bg-gold/20 mx-auto mt-6"></div>
		</div>
		
		<div class="flex flex-col gap-4">
			<EventStream direction="left" speed="60s" events={mockEventsRow1} />
			<EventStream direction="right" speed="55s" events={mockEventsRow2} />
		</div>
	</section>
</BaseLayout>
